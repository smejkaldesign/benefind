#!/usr/bin/env sh
# Pre-commit: prettier --check on staged files.
#
# Runs only on staged files so commits stay fast even on large batches.
# Failures print the offending paths and block the commit. Fix with
# `pnpm format` and re-stage.
#
# Why this exists (see SAGE retro on PR #11, Apr 2026): the first
# `pnpm format` run on this repo rewrote pnpm-lock.yaml (4000+ quote swaps)
# and reflowed docs/data-model.md (the 1061-line spec that Sprint F depends
# on). The .prettierignore landed in PR #12. This hook + the CI job in
# .github/workflows/ci.yml prevent the drift from ever recurring.

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

# Let prettier figure out which of the staged files it actually cares about
# via its own ignore rules (.prettierignore + --ignore-unknown).
echo "$STAGED_FILES" | xargs pnpm exec prettier --check --ignore-unknown
